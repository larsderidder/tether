# Tether Configuration
# Copy to .env and fill in your values

# =============================================================================
# Core Agent Settings
# =============================================================================

# Auth token for agent API (optional)
# If set, enforces bearer auth for the API/UI/MCP.
TETHER_AGENT_TOKEN=your-secure-token-here

# Development mode (optional). If enabled, the UI will not prompt for a token.
# TETHER_AGENT_DEV_MODE=1

# Host and port to bind the HTTP server
# TETHER_AGENT_HOST=0.0.0.0
# TETHER_AGENT_PORT=8787

# Directory for persistent data (sessions, logs, database)
# TETHER_AGENT_DATA_DIR=/path/to/data

# Default runner adapter for new sessions:
#   - claude_auto: Auto-detect (requires OAuth or ANTHROPIC_API_KEY)
#   - claude_subprocess: Claude via Agent SDK in subprocess (OAuth or API key)
#   - codex_sdk_sidecar: Codex SDK sidecar
#   - opencode: OpenCode via SDK sidecar (auto-managed)
#   - pi_rpc: Pi coding agent via JSON-RPC
#   - litellm: Any model via LiteLLM
#
# Note: Sessions can override this by specifying "adapter" at creation time.
# Multiple adapters can run simultaneously if credentials are configured.
TETHER_DEFAULT_AGENT_ADAPTER=claude_auto

# =============================================================================
# Logging Settings
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# TETHER_AGENT_LOG_LEVEL=INFO

# Log format: "console" for dev-friendly, "json" for structured
# TETHER_AGENT_LOG_FORMAT=console

# =============================================================================
# Session Settings
# =============================================================================

# Days to retain completed sessions before pruning (default: 7)
# TETHER_AGENT_SESSION_RETENTION_DAYS=7

# Seconds of inactivity before stopping a running session (0 = disabled)
# TETHER_AGENT_SESSION_IDLE_SECONDS=0

# Maximum seconds for a runner turn before timeout (0 = disabled)
# TETHER_AGENT_TURN_TIMEOUT_SECONDS=0

# =============================================================================
# Multi-Adapter Configuration
# =============================================================================

# You can configure multiple adapters simultaneously by providing credentials
# for each. Sessions will use the default adapter unless overridden at creation.
#
# Example: Support both Claude API and Codex SDK sidecar
#   TETHER_DEFAULT_AGENT_ADAPTER=claude_auto          # Default for new sessions
#   ANTHROPIC_API_KEY=sk-ant-...              # For Claude sessions (alternative to OAuth)
#   TETHER_CODEX_SIDECAR_URL=http://localhost:8788
#
# Create session with specific adapter via API:
#   POST /api/sessions {"directory": "/path", "adapter": "codex_sdk_sidecar"}

# =============================================================================
# Claude Settings
# =============================================================================

# API key (alternative to CLI OAuth). The Claude subprocess picks this up
# from the environment automatically.
# ANTHROPIC_API_KEY=sk-ant-...

# Model to use (default: claude-sonnet-4-20250514)
# TETHER_AGENT_CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for Claude responses (default: 4096)
# TETHER_AGENT_CLAUDE_MAX_TOKENS=4096

# =============================================================================
# Codex SDK Sidecar Adapter (when TETHER_DEFAULT_AGENT_ADAPTER=codex_sdk_sidecar)
# =============================================================================

# Base URL for the Codex SDK sidecar service (default: http://localhost:8788)
# TETHER_CODEX_SIDECAR_URL=http://localhost:8788

# Authentication token for sidecar communication (optional - auth disabled if not set)
# TETHER_CODEX_SIDECAR_TOKEN=your-sidecar-token

# Path to the Codex CLI binary (optional - SDK auto-detects from PATH)
# Note: If you run the sidecar in Docker, this path must exist inside the
# container. Prefer leaving this unset for Docker setups.
# TETHER_CODEX_SIDECAR_CODEX_BIN=/path/to/codex

# =============================================================================
# Codex SDK Sidecar Service Settings (sidecar process)
# =============================================================================

# Host and port for the sidecar HTTP server (defaults: 127.0.0.1:8788)
# TETHER_CODEX_SIDECAR_HOST=127.0.0.1
# TETHER_CODEX_SIDECAR_PORT=8788

# Sidecar logging
# TETHER_CODEX_SIDECAR_LOG_LEVEL=info
# TETHER_CODEX_SIDECAR_LOG_PRETTY=0

# Sidecar turn timeout (seconds, 0 = disabled)
# TETHER_CODEX_SIDECAR_TURN_TIMEOUT_SECONDS=0

# Optional Codex SDK tuning
# TETHER_CODEX_SIDECAR_MODEL=gpt-4.1
# TETHER_CODEX_SIDECAR_SANDBOX_MODE=workspace-write
# Network access for sandboxed execution (default: enabled)
# TETHER_CODEX_SIDECAR_NETWORK_ACCESS_ENABLED=1
# TETHER_CODEX_SIDECAR_APPROVAL_POLICY=on-request

# =============================================================================
# OpenCode SDK Sidecar Adapter (when TETHER_DEFAULT_AGENT_ADAPTER=opencode)
# =============================================================================

# Base URL for the OpenCode SDK sidecar service (default: http://localhost:8790)
# TETHER_OPENCODE_SIDECAR_URL=http://localhost:8790

# Authentication token for sidecar communication (optional)
# TETHER_OPENCODE_SIDECAR_TOKEN=your-sidecar-token

# Auto-start/stop the sidecar when Tether starts/stops (default: 1)
# TETHER_OPENCODE_SIDECAR_MANAGED=1

# Override the sidecar start command (default: uses bundled JS bundle).
# Only set this for custom setups or development.
# TETHER_OPENCODE_SIDECAR_CMD=

# Host and port for the sidecar HTTP server (defaults: 127.0.0.1:8790)
# TETHER_OPENCODE_SIDECAR_HOST=127.0.0.1
# TETHER_OPENCODE_SIDECAR_PORT=8790

# Sidecar turn timeout (seconds, 0 = disabled)
# TETHER_OPENCODE_SIDECAR_TURN_TIMEOUT_SECONDS=0

# =============================================================================
# External Session Discovery (session attach)
# =============================================================================

# Optional: Override default paths for external session discovery.
# These are used when listing and attaching to sessions from other agents.

# Claude Code session home directory (default: ~/.claude)
# CLAUDE_HOME=/path/to/.claude

# Codex session home directory (default: ~/.codex)
# CODEX_HOME=/path/to/.codex

# OpenCode binary path (default: auto-detect from ~/.opencode/bin/opencode or PATH)
# OPENCODE_BIN=/path/to/opencode

# OpenCode: XDG data directory (default: ~/.local/share)
# OpenCode uses a centralized DB at $XDG_DATA_HOME/opencode/opencode.db
# XDG_DATA_HOME=/custom/data/path

# Pi session directory (default: ~/.pi/agent/sessions)
# PI_SESSIONS_DIR=/path/to/pi/sessions

# =============================================================================
# Telegram Bridge (Optional)
# =============================================================================

# Optional: configure exactly one bridge (Telegram/Slack/Discord) or none.
# If no bridge credentials are set, the agent is accessible only via the Web UI.
#
# Bot token from @BotFather
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Supergroup ID with topics enabled (negative integer)
# TELEGRAM_FORUM_GROUP_ID=-1001234567890

# =============================================================================
# Slack Bridge (Optional)
# =============================================================================

# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_ID=C0123456789

# =============================================================================
# Discord Bridge (Optional)
# =============================================================================

# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_CHANNEL_ID=123456789012345678  # optional (can use !setup <code> instead)
# DISCORD_REQUIRE_PAIRING=0
# DISCORD_PAIRING_CODE=12345678
# DISCORD_ALLOWED_USER_IDS=123456789012345678,987654321098765432

# Debounce repeated bridge "error" status notifications (seconds)
# TETHER_AGENT_BRIDGE_ERROR_DEBOUNCE_SECONDS=30

# Upload diagnostic text attachments instead of plain error status messages.
# Enabled by default.
# TETHER_DEBUG_ATTACH_LOGS=1
